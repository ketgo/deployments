# Ollama API port (OpenAI-compatible endpoint)
OLLAMA_HOST_PORT=11434

# LiteLLM proxy port (OpenAI-compatible — use this from VS Code)
LITELLM_HOST_PORT=4000

# Open WebUI port
WEBUI_HOST_PORT=3000

# Ollama model storage — NVMe for fast model loading into VRAM
OLLAMA_DATA_HOST_VOLUME=/mnt/m2-0/ollama

# Projects volume (same var name as all other stacks)
PROJECTS_CONTAINER_VOLUME=/root/projects
PROJECTS_HOST_VOLUME=${HOME}/Projects

# Data volume
DATA_CONTAINER_VOLUME=/root/data
DATA_HOST_VOLUME=/mnt/m2-0/ai-infra
