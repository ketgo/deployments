# Exposed Port
HOST_PORT=8080

# Modules volume mount
MODULES_CONTAINER_VOLUME=~/modules
MODULES_HOST_VOLUME=${PWD}

# Projects volume mount
PROJECTS_CONTAINER_VOLUME=~/projects
PROJECTS_HOST_VOLUME=/mnt/m2-0/machine_learning/ml-projects

# Data volume mount
DATA_CONTAINER_VOLUME=~/data
DATA_HOST_VOLUME=/mnt/m2-0/machine_learning/data

# Output volume — trained model checkpoints, results, exports
OUTPUT_CONTAINER_VOLUME=~/output
OUTPUT_HOST_VOLUME=/mnt/m2-0/machine_learning/output
