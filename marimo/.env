# Exposed port on the host
HOST_PORT=2718

# Modules volume mount (shared Python packages)
MODULES_CONTAINER_VOLUME=/home/appuser/modules
MODULES_HOST_VOLUME=${PWD}

# Projects volume mount (notebooks and source code)
PROJECTS_CONTAINER_VOLUME=/home/appuser/projects
PROJECTS_HOST_VOLUME=/mnt/m2-0/machine_learning/ml-projects

# Data volume mount (datasets) — NVMe for fast notebook I/O
DATA_CONTAINER_VOLUME=/home/appuser/data
DATA_HOST_VOLUME=/mnt/m2-0/machine_learning/data

# Output volume — trained model checkpoints, results, exports
OUTPUT_CONTAINER_VOLUME=/home/appuser/output
OUTPUT_HOST_VOLUME=/mnt/m2-0/machine_learning/output
